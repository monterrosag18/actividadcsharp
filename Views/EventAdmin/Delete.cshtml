@model AnimeEventsWeb.Models.Event

@{
    ViewData["Title"] = "Eliminar Evento";
}

<div class="row">
    <div class="col s12 m6 offset-m3">
        <div class="card red lighten-5">
            <div class="card-content red-text text-darken-4">
                <span class="card-title">¿Estás seguro de eliminar esto?</span>
                <p>Estás a punto de borrar permanentemente el evento <strong>@Model.Name</strong>.</p>
                <div style="margin-top:20px;">
                    <p><strong>Fecha:</strong> @Model.Date.ToShortDateString()</p>
                    <p><strong>Ubicación:</strong> @Model.Location</p>
                    <p><strong>Categoría:</strong> @Model.Category</p>
                </div>
            </div>
            <div class="card-action right-align">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn-flat waves-effect" style="margin-right: 15px;">Cancelar</a>
                    <button type="submit" class="btn waves-effect waves-light red">
                        Confirmar Eliminación <i class="material-icons right">delete_forever</i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
