<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Theme Events Fest</title>
    <!-- Importar Google Icon Font -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <!-- Importar Materialize CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    
    <style>
        /* Estilos base simples que no usan Bootstrap */
        body {
            display: flex;
            min-height: 100vh;
            flex-direction: column;
            background-color: #fafafa;
        }
        main {
            flex: 1 0 auto;
        }
        /* Navbar theming (Color Basico Indigo) */
        nav {
            background-color: #3949ab; /* Indigo 600 */
        }
        .brand-logo {
            padding-left: 15px !important;
        }
        .page-footer {
            background-color: #283593; /* Indigo 800 */
        }
    </style>
</head>
<body>
    <header>
        <nav>
            <div class="nav-wrapper">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="brand-logo"><i class="material-icons left" style="margin-right:0px;">event</i>Events Fest</a>
                <a href="#" data-target="mobile-demo" class="sidenav-trigger"><i class="material-icons">menu</i></a>
                <ul class="right hide-on-med-and-down">
                    <li><a asp-area="" asp-controller="Home" asp-action="Index">Galería Pública</a></li>
                    <li><a asp-area="" asp-controller="EventAdmin" asp-action="Index">Admin Panel</a></li>
                </ul>
            </div>
        </nav>
        
        <ul class="sidenav" id="mobile-demo">
            <li><a asp-area="" asp-controller="Home" asp-action="Index"><i class="material-icons">collections</i>Galería Pública</a></li>
            <li><a asp-area="" asp-controller="EventAdmin" asp-action="Index"><i class="material-icons">settings</i>Admin Panel</a></li>
        </ul>
    </header>

    <main>
        <div class="container" style="margin-top: 2rem; margin-bottom: 2rem;">
            @RenderBody()
        </div>
    </main>

    <footer class="page-footer">
        <div class="footer-copyright">
            <div class="container">
                © 2026 Theme Events Fest
                <a class="grey-text text-lighten-4 right" href="#!">Powered by .NET 9 & Materialize</a>
            </div>
        </div>
    </footer>

    <!-- Materialize JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var elems = document.querySelectorAll('.sidenav');
            M.Sidenav.init(elems);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
