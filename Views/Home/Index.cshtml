@model IEnumerable<AnimeEventsWeb.Models.Event>

@{
    ViewData["Title"] = "Cartelera";
}

<div class="row" style="margin-top: 20px;">
    <div class="col s12 center-align">
        <h3 class="indigo-text text-darken-3">Eventos Destacados</h3>
        <p class="grey-text">Explora nuestra selección de eventos temáticos, festivales y convenciones.</p>
    </div>
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col s12 center-align" style="margin-top:50px;">
            <i class="material-icons large grey-text text-lighten-2">event_busy</i>
            <h5 class="grey-text">Actualmente no hay eventos registrados.</h5>
            <a asp-controller="EventAdmin" asp-action="Create" class="btn blue">Crear el primero</a>
        </div>
    }
    else
    {
        @foreach (var ev in Model)
        {
            // Determinar colores y badge según el estado
            var stateColorClass = ev.State switch {
                AnimeEventsWeb.Models.EventState.Activo => "green",
                AnimeEventsWeb.Models.EventState.Inactivo => "grey",
                AnimeEventsWeb.Models.EventState.Cancelado => "red",
                AnimeEventsWeb.Models.EventState.Finalizado => "blue",
                _ => "black"
            };

            var iconType = ev.State switch {
                AnimeEventsWeb.Models.EventState.Activo => "check_circle",
                AnimeEventsWeb.Models.EventState.Inactivo => "schedule",
                AnimeEventsWeb.Models.EventState.Cancelado => "cancel",
                AnimeEventsWeb.Models.EventState.Finalizado => "done_all",
                _ => "info"
            };

            <div class="col s12 m6 l4">
                <div class="card hoverable medium">
                    <div class="card-image waves-effect waves-block waves-light">
                        <img class="activator" src="@ev.ImageUrl" alt="@ev.Name" style="object-fit: cover; height: 100%;" onerror="this.src='https://via.placeholder.com/400x300?text=No+Image';">
                    </div>
                    <div class="card-content">
                        <span class="card-title activator grey-text text-darken-4" style="font-size: 1.2rem; font-weight: bold; line-height: 1.2;">
                            @ev.Name
                            <i class="material-icons right">more_vert</i>
                        </span>
                        <p style="margin-top: 10px;">
                            <span class="new badge @stateColorClass" data-badge-caption="" style="float: left; margin-left: 0; margin-bottom: 5px;">
                                <i class="material-icons left" style="font-size: 14px; margin-right: 5px; margin-top:4px;">@iconType</i> @ev.State
                            </span>
                        </p>
                        <div style="clear: both; padding-top: 8px;">
                            <p class="grey-text"><i class="material-icons tiny">date_range</i> @ev.Date.ToShortDateString()</p>
                            <p class="grey-text"><i class="material-icons tiny">location_on</i> @ev.Location</p>
                        </div>
                    </div>
                    <div class="card-reveal">
                        <span class="card-title grey-text text-darken-4">@ev.Name<i class="material-icons right">close</i></span>
                        <p style="margin-top:20px; font-weight:bold; color: #3949ab;">Categoría: @ev.Category</p>
                        <p>@ev.Description</p>
                        
                        <div style="position: absolute; bottom: 20px; left: 20px; right: 20px;">
                            <a href="#" class="btn waves-effect waves-light w-100 @stateColorClass" style="width: 100%;">
                                @(ev.State == AnimeEventsWeb.Models.EventState.Activo ? "Obtener Entradas" : "Más Información")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
